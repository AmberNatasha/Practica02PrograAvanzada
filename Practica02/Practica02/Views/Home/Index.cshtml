@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid mt-4">
    <div class="row align-items-center">
        <!-- Contenido de texto -->
        <div class="col-lg-8">
            <div class="text-center text-lg-start">
                <h1 class="display-4">Welcome</h1>
                <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
            </div>
        </div>
        <!-- Card con imagen -->
        <div class="col-lg-4">
            <div class="card shadow-lg border-0 h-100">
                <img src="~/img/banner.jpg.webp" class="card-img-top" alt="Banner Practica02" />
                <div class="card-body">
                    <h5 class="card-title">Sistema Practica02</h5>
                    <p class="card-text">Gestión de Clientes y Mascotas con ASP.NET Core MVC y Dapper.</p>
                    <a href="@Url.Action("Registrar", "Clientes")" class="btn btn-primary">Comenzar</a>
                </div>
            </div>
        </div>
    </div>
</div>
