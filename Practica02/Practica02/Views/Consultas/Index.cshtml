@{
    ViewData["Title"] = "Consultas";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Módulo de Consultas</h4>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-6 mb-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <i class="bi bi-person-check" style="font-size: 2rem; color: #007bff;"></i>
                                    <h6 class="mt-2">Consultar Clientes</h6>
                                    <p class="text-muted small">Próximamente disponible</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <i class="bi bi-search" style="font-size: 2rem; color: #28a745;"></i>
                                    <h6 class="mt-2">Búsqueda Avanzada</h6>
                                    <p class="text-muted small">Próximamente disponible</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="alert alert-warning" role="alert">
                        <strong>En Desarrollo:</strong> Este módulo permitirá consultar, filtrar y generar reportes
                        de clientes y mascotas registrados en la base de datos.
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <a href="@Url.Action("Registrar", "Clientes")" class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle"></i> Registrar Cliente
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="@Url.Action("Registrar", "Mascotas")" class="btn btn-success w-100">
                                <i class="bi bi-plus-circle"></i> Registrar Mascota
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
