@model List<Practica02.Controllers.ConsultasController.MascotaConsultaDto>

@{
    ViewData["Title"] = "Consulta de Mascotas";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Consulta de Mascotas Registradas</h4>
                    <a href="@Url.Action("Registrar", "Mascotas")" class="btn btn-light btn-sm">
                        <i class="bi bi-plus-circle"></i> Registrar Mascota
                    </a>
                </div>
                <div class="card-body">
                    @if (Model == null || Model.Count == 0)
                    {
                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-exclamation-circle"></i> No hay mascotas registradas aún.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Cédula del Cliente</th>
                                        <th>Nombre del Cliente</th>
                                        <th>Nombre de la Mascota</th>
                                        <th>Especie</th>
                                        <th>Peso (kg)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var mascota in Model)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-secondary">@mascota.CedulaCliente</span>
                                            </td>
                                            <td>@mascota.NombreCliente</td>
                                            <td>
                                                <strong>@mascota.NombreMascota</strong>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">@mascota.Especie</span>
                                            </td>
                                            <td>@mascota.Peso.ToString("F2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-3 text-muted small">
                            <strong>Total de mascotas:</strong> @Model.Count
                        </div>
                    }
                </div>
            </div>

            <div class="mt-4">
                <a href="@Url.Action("Index", "Consultas")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver al Módulo de Consultas
                </a>
            </div>
        </div>
    </div>
</div>
