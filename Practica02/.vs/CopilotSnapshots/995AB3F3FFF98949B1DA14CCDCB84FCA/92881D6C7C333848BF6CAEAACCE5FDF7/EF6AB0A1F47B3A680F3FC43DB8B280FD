using Microsoft.AspNetCore.Mvc;
using Practica02.Models;

namespace Practica02.Controllers
{
    public class MascotasController : Controller
    {
        // Método privado para obtener lista simulada de clientes
        private List<Cliente> ObtenerClientesSimulados()
        {
            return new List<Cliente>
            {
                new Cliente { Id = 1, Cedula = "123456789", Nombre = "Juan García" },
                new Cliente { Id = 2, Cedula = "987654321", Nombre = "María López" },
                new Cliente { Id = 3, Cedula = "456789123", Nombre = "Carlos Martínez" },
                new Cliente { Id = 4, Cedula = "789123456", Nombre = "Ana Rodríguez" },
                new Cliente { Id = 5, Cedula = "321654987", Nombre = "Roberto Fernández" }
            };
        }

        // GET: Mascotas/Registrar
        public IActionResult Registrar()
        {
            var clientes = ObtenerClientesSimulados();
            ViewBag.Clientes = clientes;
            return View(new Mascota());
        }

        // POST: Mascotas/Registrar
        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Registrar(Mascota mascota)
        {
            if (ModelState.IsValid)
            {
                // TODO: Aquí irá la lógica de persistencia en BD
                var clientes = ObtenerClientesSimulados();
                var clienteSeleccionado = clientes.FirstOrDefault(c => c.Id == mascota.ClienteId);

                TempData["Mensaje"] = $"Mascota {mascota.Nombre} registrada exitosamente para el cliente {clienteSeleccionado?.Nombre}.";
                TempData["Tipo"] = "success";
                return RedirectToAction(nameof(Registrar));
            }

            // Si hay errores de validación, mostrar el formulario nuevamente
            var clientesList = ObtenerClientesSimulados();
            ViewBag.Clientes = clientesList;
            return View(mascota);
        }
    }
}
