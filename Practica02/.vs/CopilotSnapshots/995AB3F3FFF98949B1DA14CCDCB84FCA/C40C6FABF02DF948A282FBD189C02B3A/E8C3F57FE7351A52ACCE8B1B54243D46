@{
    ViewData["Title"] = "Registro de Mascotas";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Registrar Nueva Mascota</h4>
                </div>
                <div class="card-body text-center">
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-@(TempData["Tipo"] ?? "info") alert-dismissible fade show" role="alert">
                            @TempData["Mensaje"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <i class="bi bi-paw-fill" style="font-size: 3rem; color: #28a745;"></i>
                    <h5 class="mt-3">Funcionalidad Próximamente</h5>
                    <p class="text-muted">
                        El formulario de Registro de Mascotas está en desarrollo.
                        <br />
                        Por favor, intenta más tarde o ve a <strong>Registro de Clientes</strong>.
                    </p>
                    <a href="@Url.Action("Registrar", "Clientes")" class="btn btn-primary mt-3">
                        Ir a Registro de Clientes
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
