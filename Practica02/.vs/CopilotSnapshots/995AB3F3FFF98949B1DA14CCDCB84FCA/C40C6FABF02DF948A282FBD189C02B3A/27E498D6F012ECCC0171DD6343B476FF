@model Practica02.Models.Mascota

@{
    ViewData["Title"] = "Registro de Mascotas";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Registrar Nueva Mascota</h4>
                </div>
                <div class="card-body">
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-@(TempData["Tipo"] ?? "info") alert-dismissible fade show" role="alert">
                            @TempData["Mensaje"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" asp-action="Registrar" asp-controller="Mascotas">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Fido" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Especie" class="form-label"></label>
                            <input asp-for="Especie" class="form-control" placeholder="Ej: Perro" />
                            <span asp-validation-for="Especie" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Raza" class="form-label"></label>
                            <input asp-for="Raza" class="form-control" placeholder="Ej: Labrador" />
                            <span asp-validation-for="Raza" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Peso" class="form-label"></label>
                            <input asp-for="Peso" class="form-control" placeholder="Ej: 25.5" type="number" step="0.1" />
                            <span asp-validation-for="Peso" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClienteId" class="form-label"></label>
                            <select asp-for="ClienteId" class="form-select">
                                <option value="">-- Selecciona un cliente --</option>
                                @foreach (var cliente in ViewBag.Clientes ?? new List<Practica02.Models.Cliente>())
                                {
                                    <option value="@cliente.Id">@cliente.Nombre (Cédula: @cliente.Cedula)</option>
                                }
                            </select>
                            <span asp-validation-for="ClienteId" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-check-circle"></i> Registrar Mascota
                        </button>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3" role="alert">
                <strong>Nota:</strong> Completa todos los campos. El peso debe estar entre 0.1 y 300 kg.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
