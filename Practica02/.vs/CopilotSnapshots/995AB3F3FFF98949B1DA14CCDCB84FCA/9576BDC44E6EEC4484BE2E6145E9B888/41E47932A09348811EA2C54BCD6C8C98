        /// <summary>
        /// Verifica si existen mascotas registradas para una cédula específica.
        /// </summary>
        /// <param name="cedula">Número de cédula del cliente</param>
        /// <returns>Lista de mascotas asociadas a la cédula</returns>
        [HttpGet("verificar/{cedula}")]
        public ActionResult<IEnumerable<MascotaVerificacionDto>> Verificar(string cedula)
        {
            if (string.IsNullOrWhiteSpace(cedula))
            {
                return BadRequest(new { mensaje = "La cédula es requerida." });
            }

            var mascotas = MascotasSimuladas
                .Where(m => m.Cedula == cedula.Trim())
                .ToList();

            if (mascotas.Count == 0)
            {
                return NotFound(new { mensaje = $"No se encontraron mascotas para la cédula {cedula}." });
            }

            return Ok(mascotas);
        }

        /// <summary>
        /// Obtiene todas las mascotas registradas.
        /// </summary>
        /// <returns>Lista completa de mascotas</returns>
        [HttpGet]
        public ActionResult<IEnumerable<MascotaVerificacionDto>> ObtenerTodas()
        {
            return Ok(MascotasSimuladas);
        }

        /// <summary>
        /// Obtiene una mascota específica por ID.
        /// </summary>
        /// <param name="id">ID de la mascota</param>
        /// <returns>Datos de la mascota</returns>
        [HttpGet("{id}")]
        public ActionResult<MascotaVerificacionDto> ObtenerPorId(int id)
        {
            var mascota = MascotasSimuladas.FirstOrDefault(m => m.Id == id);

            if (mascota == null)
            {
                return NotFound(new { mensaje = $"No se encontró mascota con ID {id}." });
            }

            return Ok(mascota);
        }
    }
}
